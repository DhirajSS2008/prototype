# LiquiSense Backend Environment Variables

# Database (MySQL)
DATABASE_URL=mysql+pymysql://root:12345@localhost/liqui_sense

# JWT Auth
SECRET_KEY=liqui-sense-super-secret-key-change-in-production

# Redis (disabled by default for Windows)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# Celery (requires Redis)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Claude API (optional — fallback explanations will be used if empty)
ANTHROPIC_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
